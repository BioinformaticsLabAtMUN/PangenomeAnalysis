// ============================================================================
// nextflow.config  —  Pangenome Pipeline
// ============================================================================
// $launchDir  = wherever the user types `nextflow run` (Nextflow built-in)
// $projectDir = wherever main.nf lives               (Nextflow built-in)
// ============================================================================

// ----------------------------------------------------------------------------
// Conda
// Each process in modules.nf declares its own conda env file.
// Nextflow builds it once, caches it in .conda_cache/, reuses it every run.
// ----------------------------------------------------------------------------
conda {
    enabled  = true
    cacheDir = "${launchDir}/.conda_cache"
    useMamba = false   // set true if you have mamba installed (faster builds)
}

// ----------------------------------------------------------------------------
// Default parameters
// Users can override any of them
// on the command line:  nextflow run main.nf --threads 24
// ----------------------------------------------------------------------------
params {

    // ── Identity ─────────────────────────────────────────────────────────────
    name_prefix            = 'Strep'

    // ── Working directories ───────────────────────────────────────────────────
    baseDir                = "$launchDir"
    raw_input_directory    = "${params.baseDir}/fasta_foldseek"
    gtf_directory          = "${params.baseDir}/gtf_1260"
    consolidated_dir       = "${params.baseDir}/consolidated"
    consolidated_fasta     = "${params.consolidated_dir}/consolidated.faa"
    shared_headers_file    = "${params.consolidated_dir}/shared_headers.tsv"
    metadata_file          = "${params.consolidated_dir}/metadata.tsv"
    proteome_metadata_file = "${params.baseDir}/my_proteome_metadata.tsv"

    // ── Output directories ────────────────────────────────────────────────────
    output_dir             = "${params.baseDir}/output"
    enhanced_output        = "${params.output_dir}/uniprot_output"
    cdhit_directory        = "${params.enhanced_output}/cdhit"
    swiftortho_directory   = "${params.enhanced_output}/swiftortho"
    foldseek_directory     = "${params.enhanced_output}/foldseek"
    renamed_directory      = "${params.enhanced_output}/renamed_sequences"

    // ── Tool paths (preserved from your old config) ───────────────────────────
    swiftortho_path        = "${params.baseDir}/tools/SwiftOrtho"
    foldseek_path          = 'foldseek'   // assumes foldseek is on PATH

    // ── Conda environment names
    //    These are no longer used for manual activation, but kept so any
    //    scripts that reference them don't break.
    conda_pangenome  = "pangenome_env"
    conda_goatools   = "goatools_env"
    conda_swiftortho = "swiftortho_env"

    // ── Revigo files (CD-HIT) ─────────────────────────────────────────────────
    revigo_cdhit_bp_file           = "${params.baseDir}/revigo/cdhit_acc/Revigo_BP_Table.tsv"
    revigo_cdhit_mf_file           = "${params.baseDir}/revigo/cdhit_acc/Revigo_MF_Table.tsv"

    // ── Revigo files (Foldseek) ───────────────────────────────────────────────
    revigo_foldseek_bp_file        = "${params.baseDir}/revigo/foldseek/Revigo_BP_Table.tsv"
    revigo_foldseek_mf_file        = "${params.baseDir}/revigo/foldseek/Revigo_MF_Table.tsv"

    // ── Revigo files (SwiftOrtho) ─────────────────────────────────────────────
    revigo_swiftortho_bp_file      = "${params.baseDir}/revigo/swiftortho/Revigo_BP_Table.tsv"
    revigo_swiftortho_mf_file      = "${params.baseDir}/revigo/swiftortho/Revigo_MF_Table.tsv"

    // ── Revigo files (all-gene variants) ─────────────────────────────────────
    revigo_all_cdhit_bp_file       = "${params.baseDir}/revigo/all_cdhit/Revigo_BP_Table.tsv"
    revigo_all_cdhit_mf_file       = "${params.baseDir}/revigo/all_cdhit/Revigo_MF_Table.tsv"
    revigo_all_foldseek_bp_file    = "${params.baseDir}/revigo/all_foldseek/Revigo_BP_Table.tsv"
    revigo_all_foldseek_mf_file    = "${params.baseDir}/revigo/all_foldseek/Revigo_MF_Table.tsv"

    // ── PDB / Foldseek ────────────────────────────────────────────────────────
    pdb_directory                    = "${params.baseDir}/output/pdb_files/alphafold_pdbs_ncbi"
    pdb_mapping                      = "${params.baseDir}/output/pdb_files/final_pdb_map.tsv"
    use_existing_foldseek_db         = true
    existing_foldseek_db_path        = "${params.baseDir}/foldseek_done/db"
    use_existing_foldseek_clusters   = true
    existing_foldseek_clusters_path  = "${params.baseDir}/foldseek_done/clusters/clusters.tsv"

    // ── Method & database selection ───────────────────────────────────────────
    clustering_method     = "cdhit"    // cdhit | swiftortho | foldseek | all
    database              = "uniprot"  // uniprot | ncbi

    // ── CD-HIT parameters ─────────────────────────────────────────────────────
    cdhit_identity        = 0.65
    cdhit_coverage        = 0.75
    cdhit_mode            = "accurate"
    threads               = 12

    // ── SwiftOrtho parameters ─────────────────────────────────────────────────
    swiftortho_evalue     = "1e-5"
    swiftortho_coverage   = 0.75
    min_similarity        = 0.65

    // ── Foldseek parameters (null = use Foldseek's own default) ───────────────
    foldseek_sensitivity       = null
    foldseek_num_iterations    = null
    foldseek_max_seqs          = null
    foldseek_evalue            = null
    foldseek_alignment_type    = null
    foldseek_coverage          = null
    foldseek_cov_mode          = null
    foldseek_tmscore_threshold = null
    foldseek_lddt_threshold    = null
    foldseek_threads           = 10
    foldseek_min_seq_id        = null

    // ── Annotation ────────────────────────────────────────────────────────────
    uniprot_batch_size           = 500
    uniprot_max_workers          = 8
    annotate_scope               = "core"
    max_alternatives_per_cluster = 3
    sequence_database            = "uniprot"

    // ── Misc ──────────────────────────────────────────────────────────────────
    max_strains_missing_plot = 50
    has_taxid                = false
    output_taxid             = false
    incremental_mode         = false
    new_sequences_dir        = null
    previous_cdhit_repr      = null
    previous_cdhit_clstr     = null
    sco_mapping              = "${params.baseDir}/SCO_NP_mapping.csv"
}

// ----------------------------------------------------------------------------
// Executor — preserved from your old config
// ----------------------------------------------------------------------------
executor {
    cpus   = 12
    memory = '32 GB'
}

// ----------------------------------------------------------------------------
// Per-process resource overrides
// ----------------------------------------------------------------------------
process {
    withName: 'runCDHIT' {
        cpus   = { params.threads }
        memory = '16 GB'
        time   = '6h'
    }
    withName: 'annotateSmartDominantAlleles' {
        cpus   = 2
        memory = '8 GB'
        time   = '4h'
    }
    withName: 'generatePangenomeTables' {
        cpus   = 4
        memory = '16 GB'
        time   = '2h'
    }
}

// ----------------------------------------------------------------------------
// Reporting — preserved from your old config, all three reports
// ----------------------------------------------------------------------------
report {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/execution_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/execution_timeline.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/execution_trace.txt"
}
